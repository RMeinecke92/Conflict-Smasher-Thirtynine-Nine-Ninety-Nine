# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Local bootstrap installers (large binaries — not part of the template repo)
Environment Setup/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# prisma / SQLite (local database file — never commit)
/dev.db
/prisma/*.db
/prisma/*.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
