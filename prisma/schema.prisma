generator client {
  provider = "prisma-client-js"
}

// SQLite keeps the starter app simple: the whole local database is one file.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// This example table powers the /ingredients page and shows the pattern for future bar data.
model Ingredient {
  id          Int      @id @default(autoincrement())
  name        String
  unit        String
  costPerUnit Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}